              "$ref": "#/definitions/contractsListAuditRecordsResponse"
            }
          },
          "400": {
            "description": "Bad Request - invalid parameters or malformed request",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          },
          "409": {
            "description": "Conflict",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "model",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "path",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "ruleId",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "dataType",
            "description": " - DATA_TYPE_UNSPECIFIED: Unspecified data type.\n - DATA_TYPE_CREDENTIALS: Credentials and account identifiers.\n - DATA_TYPE_API_KEYS: API keys and tokens for service access.\n - DATA_TYPE_ACCESS_TOKENS: Access tokens and bearer tokens.\n - DATA_TYPE_IP_ADDRESSES: IP addresses.\n - DATA_TYPE_PERSONAL_DATA: Personal identifiable information.\n - DATA_TYPE_CUSTOM: Custom category: rules created via the configuration API.",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "DATA_TYPE_UNSPECIFIED",
              "DATA_TYPE_CREDENTIALS",
              "DATA_TYPE_API_KEYS",
              "DATA_TYPE_ACCESS_TOKENS",
              "DATA_TYPE_IP_ADDRESSES",
              "DATA_TYPE_PERSONAL_DATA",
              "DATA_TYPE_CUSTOM"
            ],
            "default": "DATA_TYPE_UNSPECIFIED"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "until",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "limit",
            "description": "limit is the page size; 0 uses the default, capped server-side.",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "cursor",
            "description": "cursor is the opaque cursor from a previous response (\"\" = first page).",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "Guardrails"
        ]
      }
    },
