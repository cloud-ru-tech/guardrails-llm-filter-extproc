  "definitions": {
    "GuardrailsApiSetRuleEnabledBody": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Desired enabled state"
        }
      },
      "description": "SetRuleEnabledRequest enables or disables one rule. This is the only\nmutation permitted on built-in rules."
    },
    "GuardrailsApiUpdateRuleBody": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable rule name"
        },
        "group": {
          "type": "string",
          "description": "Rule group (informational)"
        },
        "dataType": {
          "$ref": "#/definitions/commonDataType",
          "description": "Data category this rule detects"
        },
        "regex": {
          "type": "string",
          "description": "RE2 detection pattern"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional keyword pre-filter terms"
        },
        "validators": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional candidate validators (e.g. luhn, entropy, ip_v4)"
        },
        "minLength": {
          "type": "integer",
          "format": "int32",
          "description": "Minimum matched length before a hit counts"
        },
        "entropy": {
          "type": "number",
          "format": "double",
          "description": "Minimum Shannon entropy for the entropy validator"
        },
        "banlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Values excluded from matching"
        },
        "masking": {
          "$ref": "#/definitions/commonMasking",
          "description": "Masking policy for this rule"
        },
        "source": {
          "type": "string",
          "description": "Response-only: \"builtin\" or \"custom\""
        },
        "enabled": {
          "type": "boolean",
          "description": "Response-only: whether the rule is currently enabled"
        }
      },
      "description": "A detection rule: RE2 regex plus optional validators and masking policy",
      "title": "Guardrail Rule"
    },
    "commonAuditRecord": {
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "mode": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "triggeredRuleIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "triggeredDataTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/commonDataType"
          }
        },
        "replacements": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonAuditReplacement"
          }
        },
        "maskedTexts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maskedResponseTexts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "masked_response_texts holds the post-masking model response texts\n(placeholders substituted, originals absent) — the response counterpart of\nmasked_texts. Populated only when GUARDRAILS_AUDIT_STORE_MASKED_RESPONSE_TEXTS\nis enabled."
        }
      },
      "description": "One per-request masking audit entry. Original values are omitted unless GUARDRAILS_AUDIT_STORE_ORIGINAL_TEXTS is enabled.",
      "title": "Audit Record"
    },
    "commonAuditReplacement": {
      "type": "object",
      "properties": {
        "ruleId": {
          "type": "string"
        },
        "dataType": {
          "$ref": "#/definitions/commonDataType"
        },
        "placeholder": {
          "type": "string"
        },
        "original": {
          "type": "string",
          "description": "original is the raw pre-masking value behind placeholder. Empty unless\nGUARDRAILS_AUDIT_STORE_ORIGINAL_TEXTS is enabled; decrypted by the API\nbefore it is returned. SECURITY: raw sensitive data — access-control it."
        }
      },
      "description": "AuditReplacement is the audit-safe projection of a masking replacement. The\noriginal value is present only when the operator opts in via\nGUARDRAILS_AUDIT_STORE_ORIGINAL_TEXTS (off by default); see original."
    },
    "commonDataType": {
      "type": "string",
      "example": "DATA_TYPE_CREDENTIALS",
      "enum": [
        "DATA_TYPE_UNSPECIFIED",
        "DATA_TYPE_CREDENTIALS",
        "DATA_TYPE_API_KEYS",
        "DATA_TYPE_ACCESS_TOKENS",
        "DATA_TYPE_IP_ADDRESSES",
        "DATA_TYPE_PERSONAL_DATA",
        "DATA_TYPE_CUSTOM"
      ],
      "default": "DATA_TYPE_UNSPECIFIED",
      "description": "Sensitive data category. Exclude DATA_TYPE_UNSPECIFIED in requests."
    },
    "commonGuardrailRule": {
      "type": "object",
      "properties": {
        "ruleId": {
          "type": "string",
          "example": "my-custom-email",
          "description": "Unique rule identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable rule name"
        },
        "group": {
          "type": "string",
          "description": "Rule group (informational)"
        },
        "dataType": {
          "$ref": "#/definitions/commonDataType",
          "description": "Data category this rule detects"
        },
        "regex": {
          "type": "string",
          "description": "RE2 detection pattern"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional keyword pre-filter terms"
        },
        "validators": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional candidate validators (e.g. luhn, entropy, ip_v4)"
        },
        "minLength": {
          "type": "integer",
          "format": "int32",
          "description": "Minimum matched length before a hit counts"
        },
        "entropy": {
          "type": "number",
          "format": "double",
          "description": "Minimum Shannon entropy for the entropy validator"
        },
        "banlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Values excluded from matching"
        },
        "masking": {
          "$ref": "#/definitions/commonMasking",
          "description": "Masking policy for this rule"
        },
        "source": {
          "type": "string",
          "description": "Response-only: \"builtin\" or \"custom\""
        },
        "enabled": {
          "type": "boolean",
          "description": "Response-only: whether the rule is currently enabled"
        }
      },
      "description": "A detection rule: RE2 regex plus optional validators and masking policy",
      "title": "Guardrail Rule"
    },
    "commonGuardrailsSettings": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether masking is enabled globally"
        },
        "dataTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/commonDataType"
          },
          "description": "Enabled data categories"
        },
        "mode": {
          "type": "string",
          "example": "enforce",
          "description": "Enforcement mode: \"enforce\" (default) or \"detect\""
        }
      },
      "description": "Global masking policy applied to all traffic",
      "title": "Guardrails Settings"
    },
    "commonMasking": {
      "type": "object",
      "properties": {
        "captureGroups": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          },
          "description": "Regex capture groups to mask; empty masks the full match"
        },
        "placeholder": {
          "type": "string",
          "example": "EMAIL",
          "description": "Placeholder base name; rendered as \u003cNAME_N\u003e"
        }
      },
      "description": "Masking describes how a detected value is replaced during masking."
    },
    "commonPlaceholder": {
      "type": "object",
      "properties": {
        "placeholder": {
          "type": "string",
          "description": "Placeholder that replaced the value, e.g. \u003cEMAIL_1\u003e"
        },
        "original": {
          "type": "string",
          "description": "Original detected value (caller's own sample; not stored)"
        },
        "ruleId": {
          "type": "string",
          "description": "Rule that produced the match"
        }
      },
      "description": "Placeholder is one original-\u003eplaceholder substitution from a dry-run scan.\nIt carries the original value, which is safe here because a scan operates on\nthe caller's own sample and persists nothing."
    },
    "contractsBulkSetRuleResult": {
      "type": "object",
      "properties": {
        "ruleId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "description": "status is \"ok\" or \"error\"."
        },
        "error": {
          "type": "string",
          "description": "error is set when status is \"error\"."
        }
      },
      "description": "BulkSetRuleResult is one rule's outcome in a bulk operation."
    },
    "contractsBulkSetRulesEnabledRequest": {
      "type": "object",
      "properties": {
        "ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Rule identifiers to update"
        },
        "enabled": {
          "type": "boolean",
          "description": "Desired enabled state applied to every id"
        }
      },
      "description": "BulkSetRulesEnabledRequest enables or disables many rules in one call."
    },
    "contractsBulkSetRulesEnabledResponse": {
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/contractsBulkSetRuleResult"
          }
        }
      },
      "description": "BulkSetRulesEnabledResponse reports the per-rule outcome. The operation is\nbest-effort: each id is attempted independently and failures are reported\nper item rather than aborting the batch."
    },
    "contractsDataTypeInfo": {
      "type": "object",
      "properties": {
        "dataType": {
          "type": "integer",
          "format": "int32",
          "description": "Numeric data-type ID"
        },
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "description": "DataTypeInfo describes one toggleable data-type group."
    },
    "contractsGetDataTypesResponse": {
      "type": "object",
      "properties": {
        "dataTypes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/contractsDataTypeInfo"
          }
        }
      },
      "description": "GetDataTypesResponse is the catalog of data-type groups plus CUSTOM."
    },
    "contractsGetVersionResponse": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "description": "mode is the live masking mode (\"enforce\" or \"detect\")."
        },
        "storeBackend": {
          "type": "string"
        },
        "topology": {
          "type": "string"
        }
      },
      "description": "GetVersionResponse is the service build identity plus the live masking mode."
    },
    "contractsListAuditRecordsResponse": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonAuditRecord"
          }
        },
        "nextCursor": {
          "type": "string",
          "description": "next_cursor is empty when the listing is exhausted."
        }
      },
      "description": "ListAuditRecordsResponse is one page of audit records."
    },
    "contractsListRulesResponse": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonGuardrailRule"
          }
        }
      },
      "description": "ListRulesResponse is the list of rules."
    },
    "contractsScanRequest": {
      "type": "object",
      "properties": {
        "texts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Sample inputs to scan"
        },
        "text": {
          "type": "string",
          "description": "Single sample convenience; used only when texts is empty"
        },
        "dataTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/commonDataType"
          },
          "description": "Limit the scan to these data types; empty means all"
        },
        "candidateRule": {
          "$ref": "#/definitions/commonGuardrailRule",
          "description": "Optional not-yet-saved rule to test"
        }
      },
      "description": "ScanRequest is a dry-run masking check. It reuses the production scan+mask\npipeline but persists nothing and calls no upstream."
    },
    "contractsScanResponse": {
      "type": "object",
      "properties": {
        "maskedTexts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "triggeredRuleIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "triggeredDataTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/commonDataType"
          }
        },
        "placeholders": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonPlaceholder"
          }
        },
        "totalMs": {
          "type": "integer",
          "format": "int32",
          "description": "total_ms is the scan wall-clock time in milliseconds."
        }
      },
      "description": "ScanResponse is the dry-run scan result. Nothing here is persisted."
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
}
