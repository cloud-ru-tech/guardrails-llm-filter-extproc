{
  "swagger": "2.0",
  "info": {
    "title": "Guardrails Management API",
    "description": "Management API for the standalone guardrails service: custom rule CRUD, global settings, data-type discovery and dry-run masking checks. The data-plane LLM proxy is a separate HTTP surface and is not part of this contract.",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "Guardrails",
      "description": "Rule, settings and data-type management, plus dry-run scan"
    }
  ],
  "schemes": [
    "http",
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
