{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping guardrails-llm-filter-extproc :9090/metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "guardrails-llm-filter-extproc: PII/secrets masking for LLM traffic. Traffic & detections, pipeline latency, fail-open errors, gRPC health. Alert thresholds mirror deploy/prometheus/guardrails-llm-filter-extproc-alerts.yml (Prometheus rules remain the alerting source of truth).",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["guardrails-llm-filter-extproc", "extproc", "llm"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "rule_id",
        "label": "Rule",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(extproc_guardrails_rule_triggers_total, rule_id)",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "data_type",
        "label": "Data type",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(extproc_guardrails_data_type_triggers_total, data_type)",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Extproc Guardrails",
  "uid": "guardrails-llm-filter-extproc",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "Traffic & detections",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Requests with detections (by mode)",
      "description": "Requests where at least one value was masked (enforce) or would have been (detect). Same series family the GuardrailsMaskedTrafficSpike alert sums over — during a shadow rollout compare detect vs enforce here.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(extproc_guardrails_requests_masked_total[$__rate_interval]))",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Top 10 triggered rules",
      "description": "Rule-level hits over the dashboard time range (a request can trigger a rule several times).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "continuous-BlPu" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (rule_id) (increase(extproc_guardrails_rule_triggers_total{rule_id=~\"$rule_id\"}[$__range])))",
          "legendFormat": "{{rule_id}}",
          "instant": true
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Triggers by data type",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (data_type) (rate(extproc_guardrails_data_type_triggers_total{data_type=~\"$data_type\"}[$__rate_interval]))",
          "legendFormat": "{{data_type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Distinct rules triggered per request (p50 / p99)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(extproc_guardrails_triggered_rules_count_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(extproc_guardrails_triggered_rules_count_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Pipeline duration (mask + demask)",
      "description": "GuardrailsPipelineSlow alerts when p99 > 1s for 10m.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "custom.thresholdsStyle", "value": { "mode": "line" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "red", "value": 1 }] } }]
          }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(extproc_guardrails_pipeline_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.90, sum by (le) (rate(extproc_guardrails_pipeline_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p90" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(extproc_guardrails_pipeline_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Mask / scan duration (p99)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(extproc_guardrails_mask_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "mask (request total)" },
        { "refId": "B", "expr": "histogram_quantile(0.99, sum by (le) (rate(extproc_guardrails_mask_scan_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "scan (all texts)" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(extproc_guardrails_scan_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "scan (per text)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Demask duration (p99)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(extproc_guardrails_demask_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "full body" },
        { "refId": "B", "expr": "histogram_quantile(0.99, sum by (le) (rate(extproc_guardrails_sse_chunk_demask_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "SSE chunk" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Scanned volume",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "texts/s" }, "properties": [{ "id": "unit", "value": "ops" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(extproc_guardrails_mask_scan_total_bytes_sum[$__rate_interval]))", "legendFormat": "bytes/s" },
        { "refId": "B", "expr": "sum(rate(extproc_guardrails_mask_texts_count_sum[$__rate_interval]))", "legendFormat": "texts/s" }
      ]
    },
    {
      "type": "row",
      "title": "Errors (fail-open events)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Mask failures (5m increase)",
      "description": "Requests passed through UNMASKED because the mask pipeline errored. GuardrailsMaskingFailures fires (critical) on any increase.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "custom": { "thresholdsStyle": { "mode": "line" }, "drawStyle": "bars", "fillOpacity": 60 }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "increase(extproc_guardrails_mask_failures_total[5m])", "legendFormat": "mask failures" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Demask failures / masked fallbacks (5m increase)",
      "description": "Client saw placeholders instead of original values. GuardrailsDemaskFailures fires (warning) on any increase.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (mode) (increase(extproc_guardrails_demask_failures_total[5m]))", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Masking-state store failures by op (5m increase)",
      "description": "Fail-open store errors; cross-replica demasking may degrade. GuardrailsStateStoreFailures fires (warning) on any increase.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (op) (increase(extproc_guardrails_masking_state_store_failures_total[5m]))", "legendFormat": "{{op}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Audit: store failures & dropped records (5m increase)",
      "description": "put = fail-open async writes (GuardrailsAuditWriteFailures); dropped = write queue saturated (GuardrailsAuditRecordsDropped).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (op) (increase(extproc_guardrails_audit_store_failures_total[5m]))", "legendFormat": "store {{op}}" },
        { "refId": "B", "expr": "increase(extproc_guardrails_audit_records_dropped_total[5m])", "legendFormat": "dropped" }
      ]
    },
    {
      "type": "row",
      "title": "gRPC / service health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "ext_proc streams handled (by gRPC code)",
      "description": "One stream per HTTP request/response cycle. No gRPC latency histogram is exported; use the pipeline duration panel for timing.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 52 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (grpc_code) (rate(grpc_server_handled_total{grpc_service=\"envoy.service.ext_proc.v3.ExternalProcessor\"}[$__rate_interval]))",
          "legendFormat": "{{grpc_code}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Scrape targets up",
      "description": "GuardrailsScrapeDown fires (critical) when 0 or absent for 5m.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 52 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sum(up{job=~\".*guardrails-llm-filter-extproc.*\"}) or vector(0)", "legendFormat": "instances up" }
      ]
    }
  ]
}
